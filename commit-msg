#!/usr/bin/env bash
# commit-msg hook: validate Co-authored-by trailers
#
# Format: Co-authored-by: <agent> + <model> <<email>>
#
# Known agents:  omp, codewhale, Claude, opencode
#
# Known model vendors and their email domains:
#   DeepSeek           -> @deepseek.com
#   Claude / Anthropic -> @anthropic.com
#   OpenAI / GPT       -> @openai.com
#   opencode           -> @anthropic.com
#
# Model names must include version/descriptor (e.g. "v4 Pro", "Sonnet 4"),
# not just the bare vendor name (e.g. "DeepSeek" alone is rejected).
#
# Install via pre-commit (.pre-commit-config.yaml):
#   - repo: https://github.com/rurban/check-agent-trailer
#     rev: v0.1
#     hooks:
#       - id: check-agent-trailer

set -euo pipefail

COMMIT_MSG_FILE="${1:-}"
if [ -z "$COMMIT_MSG_FILE" ]; then
    echo "ERROR: no commit message file argument" >&2
    exit 1
fi

trailer=$(grep "^Co-authored-by:" "$COMMIT_MSG_FILE" | tail -1)

if [ -z "$trailer" ]; then
    echo "ERROR: Missing Co-authored-by: trailer in commit message" >&2
    echo "  Format: Co-authored-by: <agent> + <model> <email@domain>" >&2
    echo "  Example: Co-authored-by: omp + DeepSeek v4 Pro <deepseek-v4-pro@deepseek.com>" >&2
    exit 1
fi

# ── extract fields ──────────────────────────────────────────────
email=$(echo "$trailer" | sed -n 's/.*<\([^>]*\)>.*/\1/p')
if [ -z "$email" ]; then
    echo "ERROR: Co-authored-by trailer missing email in <brackets>" >&2
    exit 1
fi

name=$(echo "$trailer" | sed -n 's/^Co-authored-by: \(.*\) <.*/\1/p')
if [[ "$name" != *" + "* ]]; then
    echo "ERROR: Co-authored-by must include both agent and model separated by ' + '" >&2
    echo "  Got:      $name" >&2
    echo "  Expected: <agent> + <model>" >&2
    exit 1
fi

agent="${name%% + *}"
model="${name#* + }"

# ── known agents ─────────────────────────────────────────────────
known_agents=("omp" "codewhale" "Claude" "opencode")
agent_ok=0
for a in "${known_agents[@]}"; do
    if [ "$agent" = "$a" ]; then agent_ok=1; break; fi
done
if [ "$agent_ok" -ne 1 ]; then
    echo "ERROR: Unknown agent '$agent'" >&2
    echo "  Known agents: ${known_agents[*]}" >&2
    exit 1
fi

# ── model must include version, not bare vendor ──────────────────
bare_vendors=("DeepSeek" "deepseek" "Claude" "claude" "GPT" "gpt" "OpenAI" "openai" "opencode" "OpenCode")
for bv in "${bare_vendors[@]}"; do
    if [ "$model" = "$bv" ]; then
        echo "ERROR: Model name must include version/descriptor, not just vendor" >&2
        echo "  Got:      $model" >&2
        echo "  Expected: e.g. 'DeepSeek v4 Pro', 'Claude Sonnet 4', 'GPT-5'" >&2
        exit 1
    fi
done

# ── email domain → model vendor mapping ──────────────────────────
# Associative array: glob_pattern -> expected_domain
declare -A vendor_domains=(
    ["*DeepSeek*"]="deepseek.com"
    ["*deepseek*"]="deepseek.com"
    ["*Claude*"]="anthropic.com"
    ["*claude*"]="anthropic.com"
    ["*GPT*"]="openai.com"
    ["*gpt*"]="openai.com"
    ["*OpenAI*"]="openai.com"
    ["*openai*"]="openai.com"
    ["*opencode*"]="openai.com"
    ["*OpenCode*"]="openai.com"
)

domain="${email##*@}"
expected_domain="anthropic.com"  # default fallback
for pattern in "${!vendor_domains[@]}"; do
    if [[ "$model" == $pattern ]]; then
        expected_domain="${vendor_domains[$pattern]}"
        break
    fi
done

if [ "$domain" != "$expected_domain" ]; then
    echo "ERROR: Wrong email domain for model '$model'" >&2
    echo "  Got:      $email" >&2
    echo "  Expected: <...@$expected_domain>" >&2
    exit 1
fi

exit 0
